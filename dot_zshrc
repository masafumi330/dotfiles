# Set personal aliases, overriding those provided by Oh My Zsh libs,
# plugins, and themes. Aliases can be placed here, though Oh My Zsh
# users are encouraged to define aliases within a top-level file in
# the $ZSH_CUSTOM folder, with .zsh extension. Examples:
# - $ZSH_CUSTOM/aliases.zsh
# - $ZSH_CUSTOM/macos.zsh
# For a full list of active aliases, run `alias`.
#
# Example aliases
# alias zshconfig="mate ~/.zshrc"
# alias ohmyzsh="mate ~/.oh-my-zsh"
#
## Aliases -------------------------------------------------------------------
# Editor
alias v='nvim'
alias cat='bat'
alias today-nippo="nvim ~/nippo/$(date +%Y-%m-%d).md"

# Git
alias gc='git checkout'
alias gs='git status'
alias gb='git branch'
alias ga='git add'
alias gm='gitmoji -c'
alias gpfirst='git push -u origin HEAD' # HEAD にすることで「今いるブランチ名を自動で使う」動作に
alias gp='git push'
alias pull='git pull'

export PATH="$HOME/.local/bin:$PATH"

## fzf -------------------------------------------------------------------
# Ctrl+R: コマンド履歴検索 / Ctrl+T: ファイル選択 / Alt+C: ディレクトリ移動
source <(fzf --zsh)

## ghq + fzf ---------------------------------------------------------------
# Ctrl+G で ghq 管理リポジトリを fzf で選択して cd する ZLE ウィジェット
function _ghq_fzf_widget() {
  local root repo
  root=$(ghq root)
  # ghq list でリポジトリ一覧を取得し、fzf でインタラクティブに選択
  # --preview でリポジトリ内のファイル一覧を右ペインに表示
  repo=$(ghq list | fzf )
  if [[ -n "$repo" ]]; then
    BUFFER="cd ${root}/${repo}"
    zle accept-line  # 選択後に Enter を自動実行
  fi
  zle reset-prompt
}
zle -N _ghq_fzf_widget       # 関数を ZLE ウィジェットとして登録
bindkey '^g' _ghq_fzf_widget # Ctrl+G に割り当て

# apply shell integration
source /Applications/WezTerm.app/Contents/Resources/wezterm.sh

[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
